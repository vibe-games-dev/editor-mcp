{
  "name": "@vibegames/editor-mcp",
  "version": "0.0.1",
  "type": "module",
  "description": "Local MCP server that bridges external MCP clients to the Vibe Games browser editor over a WebSocket.",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "vibe-games-editor-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector -e PORT=8765 -e EDITOR_MCP_TOKEN=dev tsx src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
